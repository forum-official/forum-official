/*.js
/*.cjs
/*.py
/*.ps1
/temp_*
/yes24_replace_progress.json

# Explicitly keep these root config files
!/package.json
!/package-lock.json
!/tsconfig.json
!/vite.config.ts
!/postcss.config.mjs
!/pnpm-workspace.yaml
!/index.html
!/README.md
!/ATTRIBUTIONS.md
!/.gitignore
