# Dependencies
node_modules/
/dist/
/.env
/.env.local
/.env.development.local
/.env.test.local
/.env.production.local

# Log files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Editor directories and files
.idea/
.vscode/
*.suo
